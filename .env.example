# Database — local dev: file:./prisma/dev.db  |  production: libsql://[name].turso.io
DATABASE_URL="file:./prisma/dev.db"
DATABASE_AUTH_TOKEN=""

# NextAuth
NEXTAUTH_SECRET="generate-a-strong-random-string"
NEXTAUTH_URL="http://localhost:3002"
NEXT_PUBLIC_APP_URL="http://localhost:3002"

# Email (Resend) — https://resend.com
RESEND_API_KEY=""

# File uploads (Uploadthing) — https://uploadthing.com
UPLOADTHING_TOKEN=""

# Cron job secret — protects /api/cron/* from unauthorized calls
# Generate with: openssl rand -base64 32
CRON_SECRET=""

# Anthropic API key — powers the AI weekly summary feature
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=""

# Field-level encryption for PII (phone numbers, etc.)
# Generate with: openssl rand -hex 32
# IMPORTANT: Back up this key — losing it means losing access to encrypted data
ENCRYPTION_KEY=""

# Upstash Redis — production-grade rate limiting (optional, falls back to in-memory)
# Get from: https://upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
