# Database — PostgreSQL connection string
# Local dev: postgresql://user:password@localhost:5432/cadence
# Production: Use your hosted PostgreSQL URL (Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/cadence"

# NextAuth
NEXTAUTH_SECRET="generate-a-strong-random-string"
NEXTAUTH_URL="http://localhost:3002"
NEXT_PUBLIC_APP_URL="http://localhost:3002"

# Email (Resend) — https://resend.com
RESEND_API_KEY=""

# File uploads (Uploadthing) — https://uploadthing.com
UPLOADTHING_TOKEN=""

# Cron job secret — protects /api/cron/check-automations from unauthorized calls
# Generate with: openssl rand -base64 32
CRON_SECRET=""

# Anthropic API key — powers the AI weekly summary feature
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=""
